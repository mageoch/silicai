{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mageoch/silicai/schema/defs/pin_electrical.schema.json",
  "title": "Pin Electrical Characteristics",
  "type": "object",
  "properties": {
    "v_ih_min": {
      "oneOf": [
        { "$ref": "measured_value.schema.json" },
        { "$ref": "relative_threshold.schema.json" }
      ]
    },
    "v_il_max": {
      "oneOf": [
        { "$ref": "measured_value.schema.json" },
        { "$ref": "relative_threshold.schema.json" }
      ]
    },
    "v_oh_min": {
      "oneOf": [
        { "$ref": "measured_value.schema.json" },
        { "$ref": "relative_threshold.schema.json" }
      ]
    },
    "v_ol_max":   { "$ref": "measured_value.schema.json" },
    "i_oh_max":   { "$ref": "measured_value.schema.json" },
    "i_ol_max":   { "$ref": "measured_value.schema.json" },
    "i_leak_max": { "$ref": "measured_value.schema.json" }
  }
}
