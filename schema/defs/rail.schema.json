{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mageoch/silicai/schema/defs/rail.schema.json",
  "title": "Rail",
  "description": "A power supply rail with its decoupling requirements",
  "type": "object",
  "required": ["id", "net"],
  "properties": {
    "id":  { "type": "string" },
    "net": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["power", "internal_node"]
    },
    "input_filter": {
      "type": "array",
      "items": { "$ref": "passive_component.schema.json" }
    },
    "per_pin_decoupling": {
      "type": "array",
      "items": { "$ref": "passive_component.schema.json" }
    },
    "bulk_decoupling": {
      "type": "array",
      "items": { "$ref": "passive_component.schema.json" }
    }
  }
}
