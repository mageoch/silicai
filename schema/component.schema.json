{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mageoch/silicai/schema/component.schema.json",
  "title": "SilicAI Component",
  "description": "Structured description of an electronic component for AI-assisted circuit design",
  "type": "object",
  "required": ["component"],
  "properties": {
    "$schema": { "type": "string" },
    "$schema_version": { "type": "string" },
    "component": {
      "type": "object",
      "required": ["mpn", "manufacturer", "category", "package", "pins"],
      "properties": {
        "mpn": { "type": "string" },
        "manufacturer": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["mcu", "mpu", "power_ic", "power_discrete", "analog", "logic", "memory", "wireless", "sensor", "passive", "connector", "discrete"]
        },
        "package": { "type": "string" },
        "datasheet": { "type": "string", "format": "uri" },

        "specifications": { "$ref": "#/$defs/specifications" },

        "absolute_maximum_ratings": {
          "type": "array",
          "items": { "$ref": "#/$defs/rating" }
        },

        "recommended_operating_conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/rating" }
        },

        "rails": {
          "type": "array",
          "items": { "$ref": "#/$defs/rail" }
        },

        "pins": {
          "type": "array",
          "items": { "$ref": "#/$defs/pin" }
        },

        "interfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/interface" }
        }
      }
    }
  },

  "$defs": {

    "measured_value": {
      "type": "object",
      "required": ["value", "unit"],
      "properties": {
        "value": { "type": "number" },
        "unit": { "type": "string" }
      },
      "additionalProperties": false
    },

    "range_value": {
      "type": "object",
      "required": ["min", "max", "unit"],
      "properties": {
        "min": { "type": "number" },
        "max": { "type": "number" },
        "unit": { "type": "string" }
      },
      "additionalProperties": false
    },

    "relative_threshold": {
      "description": "Voltage threshold expressed as a fraction of a reference voltage (e.g. 0.7 * V+)",
      "type": "object",
      "required": ["multiplier", "reference"],
      "properties": {
        "multiplier": { "type": "number" },
        "reference": { "type": "string" }
      },
      "additionalProperties": false
    },

    "specifications": {
      "type": "object",
      "properties": {
        "resistance":            { "$ref": "#/$defs/measured_value" },
        "capacitance":           { "$ref": "#/$defs/measured_value" },
        "inductance":            { "$ref": "#/$defs/measured_value" },
        "tolerance":             { "$ref": "#/$defs/measured_value" },
        "voltage_rating":        { "$ref": "#/$defs/measured_value" },
        "power_rating":          { "$ref": "#/$defs/measured_value" },
        "current_rating":        { "$ref": "#/$defs/measured_value" },
        "dielectric":            { "type": "string" },
        "temperature_coefficient": { "$ref": "#/$defs/measured_value" },
        "temperature_range":     { "$ref": "#/$defs/range_value" },
        "dc_resistance":         { "$ref": "#/$defs/measured_value" }
      }
    },

    "rating": {
      "description": "One row of an absolute maximum ratings or recommended operating conditions table",
      "type": "object",
      "required": ["parameter", "pins", "unit"],
      "properties": {
        "parameter": { "type": "string" },
        "pins": { "type": "array", "items": { "type": "string" } },
        "unit": { "type": "string" },
        "min": { "type": "number" },
        "nom": { "type": "number" },
        "max": { "type": "number" }
      }
    },

    "rail": {
      "type": "object",
      "required": ["id", "net"],
      "properties": {
        "id": { "type": "string" },
        "net": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["power", "internal_node"]
        },
        "input_filter": {
          "type": "array",
          "items": { "$ref": "#/$defs/passive_component" }
        },
        "per_pin_decoupling": {
          "type": "array",
          "items": { "$ref": "#/$defs/passive_component" }
        },
        "bulk_decoupling": {
          "type": "array",
          "items": { "$ref": "#/$defs/passive_component" }
        }
      }
    },

    "pin": {
      "type": "object",
      "required": ["number", "name", "direction"],
      "properties": {
        "number": { "type": "integer" },
        "name": { "type": "string" },
        "direction": {
          "type": "string",
          "enum": ["input", "output", "bidirectional", "tri_state", "passive", "open_collector", "open_emitter", "power_in", "power_out", "no_connect"]
        },
        "open_drain": { "type": "boolean" },
        "must_connect": { "type": "boolean" },
        "rail": { "type": "string" },
        "net": { "type": "string" },
        "voltage_level": { "$ref": "#/$defs/measured_value" },
        "electrical": { "$ref": "#/$defs/pin_electrical" },
        "primary_function": { "$ref": "#/$defs/pin_function" },
        "alternate_functions": {
          "type": "array",
          "items": { "$ref": "#/$defs/alternate_function" }
        },
        "required_external": {
          "type": "array",
          "items": { "$ref": "#/$defs/passive_component" }
        }
      }
    },

    "pin_electrical": {
      "type": "object",
      "properties": {
        "v_ih_min":   {
          "oneOf": [
            { "$ref": "#/$defs/measured_value" },
            { "$ref": "#/$defs/relative_threshold" }
          ]
        },
        "v_il_max":   {
          "oneOf": [
            { "$ref": "#/$defs/measured_value" },
            { "$ref": "#/$defs/relative_threshold" }
          ]
        },
        "v_oh_min":   {
          "oneOf": [
            { "$ref": "#/$defs/measured_value" },
            { "$ref": "#/$defs/relative_threshold" }
          ]
        },
        "v_ol_max":   { "$ref": "#/$defs/measured_value" },
        "i_oh_max":   { "$ref": "#/$defs/measured_value" },
        "i_ol_max":   { "$ref": "#/$defs/measured_value" },
        "i_leak_max": { "$ref": "#/$defs/measured_value" }
      }
    },

    "pin_function": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "gpio", "reset", "boot_select",
            "clock_in", "clock_out",
            "power", "analog_in", "analog_out", "differential_pair",
            "i2c_scl", "i2c_sda",
            "spi_sck", "spi_mosi", "spi_miso", "spi_cs",
            "uart_tx", "uart_rx",
            "alert", "address_select", "enable", "interrupt", "pwm"
          ]
        },
        "polarity": { "type": "string", "enum": ["active_high", "active_low"] },
        "port":     { "type": "string" },
        "bit":      { "type": "integer" },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/address_select_option" }
        }
      }
    },

    "address_select_option": {
      "type": "object",
      "required": ["connect_to", "i2c_address"],
      "properties": {
        "connect_to":   { "type": "string" },
        "i2c_address":  { "type": "string" }
      }
    },

    "alternate_function": {
      "type": "object",
      "required": ["peripheral", "signal", "direction"],
      "properties": {
        "af":        {},
        "peripheral": { "type": "string" },
        "signal":    { "type": "string" },
        "direction": {
          "type": "string",
          "enum": ["input", "output", "bidirectional"]
        }
      }
    },

    "passive_component": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["capacitor", "resistor", "ferrite_bead", "inductor", "crystal", "diode"]
        },
        "resistance":          { "$ref": "#/$defs/measured_value" },
        "capacitance":         { "$ref": "#/$defs/measured_value" },
        "inductance":          { "$ref": "#/$defs/measured_value" },
        "impedance_at_100mhz": { "$ref": "#/$defs/measured_value" },
        "voltage_rating":      { "$ref": "#/$defs/measured_value" },
        "current_rating":      { "$ref": "#/$defs/measured_value" },
        "esr":                 { "$ref": "#/$defs/measured_value" },
        "dielectric": {
          "type": "array",
          "items": { "type": "string" }
        },
        "placement": {
          "type": "string",
          "enum": ["close", "nearby", "per_pin", "per_component"]
        },
        "quantity": {
          "type": "string",
          "enum": ["1", "per_pin", "per_component"]
        },
        "scope": {
          "type": "string",
          "enum": ["component", "bus"],
          "description": "component: one per IC instance. bus: shared across all devices on the bus."
        },
        "from": { "type": "string" },
        "to":   { "type": "string" }
      }
    },

    "interface": {
      "type": "object",
      "required": ["type", "pins"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["I2C", "SPI", "UART", "USB", "CAN", "Ethernet", "SDIO", "I2S", "SAI", "ADC", "DAC", "JTAG", "SWD", "SMBus", "1-Wire"]
        },
        "instance":  { "type": "integer" },
        "speed_min": { "$ref": "#/$defs/measured_value" },
        "speed_max": { "$ref": "#/$defs/measured_value" },
        "pins": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
