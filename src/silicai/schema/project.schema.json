{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/mageoch/silicai/main/src/silicai/schema/project.schema.json",
  "title": "SilicAI Project",
  "description": "Top-level project definition grouping one or more circuits into a KiCad project",
  "type": "object",
  "required": ["$schema", "$schema_version", "project"],
  "properties": {
    "$schema":         { "type": "string" },
    "$schema_version": { "type": "string" },
    "project": {
      "type": "object",
      "required": ["name", "circuits"],
      "properties": {
        "name":        { "type": "string", "description": "Human-readable project name (used as KiCad project title)" },
        "revision":    { "type": "string", "description": "Revision string (e.g. 1.0, A, rev2)" },
        "company":     { "type": "string", "description": "Company or author name for title block" },
        "description": { "type": "string", "description": "Short description of the project" },
        "shared": {
          "type": "object",
          "description": "Resources shared across all circuits in this project (power rails, buses)",
          "properties": {
            "power_rails": {
              "type": "array",
              "items": { "$ref": "defs/circuit_power_rail.schema.json" }
            },
            "buses": {
              "type": "array",
              "items": { "$ref": "defs/circuit_bus.schema.json" }
            }
          },
          "additionalProperties": false
        },
        "circuits": {
          "type": "array",
          "description": "Ordered list of circuit YAML paths (relative to this file). Each becomes a sub-sheet in the KiCad schematic.",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  }
}
