{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mageoch/silicai/schema/defs/alternate_function.schema.json",
  "title": "Alternate Pin Function",
  "description": "An alternate peripheral function available on a GPIO pin",
  "type": "object",
  "required": ["peripheral", "signal", "direction"],
  "properties": {
    "af":         {},
    "peripheral": { "type": "string" },
    "signal":     { "type": "string" },
    "direction": {
      "type": "string",
      "enum": ["input", "output", "bidirectional"]
    }
  }
}
