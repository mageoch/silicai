{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/mageoch/silicai/main/src/silicai/schema/defs/range_value.schema.json",
  "title": "Range Value",
  "description": "A numeric range with an explicit unit",
  "type": "object",
  "required": ["min", "max", "unit"],
  "properties": {
    "min":  { "type": "number", "description": "Minimum value of the range" },
    "max":  { "type": "number", "description": "Maximum value of the range" },
    "unit": { "type": "string", "description": "Unit of measurement (e.g. °C, V)" }
  },
  "additionalProperties": false
}
