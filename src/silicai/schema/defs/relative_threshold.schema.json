{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mageoch/silicai/schema/defs/relative_threshold.schema.json",
  "title": "Relative Threshold",
  "description": "A voltage threshold expressed as a fraction of a reference voltage (e.g. 0.7 × V+)",
  "type": "object",
  "required": ["multiplier", "reference"],
  "properties": {
    "multiplier": { "type": "number" },
    "reference":  { "type": "string" }
  },
  "additionalProperties": false
}
