{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mageoch.github.io/silicai/schema/defs/temperature_range.schema.json",
  "title": "Temperature Range",
  "description": "Operating, storage, and thermal characteristics of a component",
  "type": "object",
  "properties": {
    "operating": {
      "type": "object",
      "description": "Ambient temperature range for normal operation",
      "required": ["min", "max"],
      "properties": {
        "min": { "$ref": "measured_value.schema.json" },
        "max": { "$ref": "measured_value.schema.json" }
      }
    },
    "storage": {
      "type": "object",
      "description": "Allowable temperature range during storage (unpowered)",
      "required": ["min", "max"],
      "properties": {
        "min": { "$ref": "measured_value.schema.json" },
        "max": { "$ref": "measured_value.schema.json" }
      }
    },
    "junction_max": {
      "$ref": "measured_value.schema.json",
      "description": "Maximum junction temperature (Tj_max), typically 125°C or 150°C"
    },
    "thermal_resistance_ja": {
      "$ref": "measured_value.schema.json",
      "description": "Junction-to-ambient thermal resistance (Θja) in °C/W"
    }
  }
}
