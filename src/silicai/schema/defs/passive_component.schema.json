{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mageoch.github.io/silicai/schema/defs/passive_component.schema.json",
  "title": "Passive Component",
  "description": "A passive component used in decoupling, filtering, or required external circuits",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "description": "Component type",
      "enum": ["capacitor", "resistor", "ferrite_bead", "inductor", "crystal", "diode"]
    },
    "resistance":          { "$ref": "measured_value.schema.json", "description": "Resistance value (for resistors and pull-ups)" },
    "capacitance":         { "$ref": "measured_value.schema.json", "description": "Capacitance value (for capacitors)" },
    "inductance":          { "$ref": "measured_value.schema.json", "description": "Inductance value (for inductors)" },
    "impedance_at_100mhz": { "$ref": "measured_value.schema.json", "description": "Impedance at 100 MHz (for ferrite beads)" },
    "voltage_rating":      { "$ref": "measured_value.schema.json", "description": "Maximum rated voltage" },
    "current_rating":      { "$ref": "measured_value.schema.json", "description": "Maximum rated continuous current" },
    "esr":                 { "$ref": "measured_value.schema.json", "description": "Equivalent series resistance (for capacitors)" },
    "dielectric": {
      "type": "array",
      "description": "Acceptable capacitor dielectrics in order of preference (e.g. [X5R, X7R])",
      "items": { "type": "string" }
    },
    "placement": {
      "type": "string",
      "description": "Required placement proximity relative to the associated pin or component",
      "enum": ["close", "nearby", "per_pin", "per_component"]
    },
    "quantity": {
      "type": "string",
      "description": "How many instances of this component are needed",
      "enum": ["1", "per_pin", "per_component"]
    },
    "scope": {
      "type": "string",
      "enum": ["component", "bus"],
      "description": "component: one per IC instance. bus: shared across all devices on the bus."
    },
    "from": { "type": "string", "description": "Source pin name this component connects from" },
    "to":   { "type": "string", "description": "Destination net name this component connects to" },
    "remark": { "type": "string", "description": "Free-form note about why this component is needed or how to select it" }
  }
}
