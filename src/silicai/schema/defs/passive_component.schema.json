{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mageoch/silicai/schema/defs/passive_component.schema.json",
  "title": "Passive Component",
  "description": "A passive component used in decoupling, filtering, or required external circuits",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["capacitor", "resistor", "ferrite_bead", "inductor", "crystal", "diode"]
    },
    "resistance":          { "$ref": "measured_value.schema.json" },
    "capacitance":         { "$ref": "measured_value.schema.json" },
    "inductance":          { "$ref": "measured_value.schema.json" },
    "impedance_at_100mhz": { "$ref": "measured_value.schema.json" },
    "voltage_rating":      { "$ref": "measured_value.schema.json" },
    "current_rating":      { "$ref": "measured_value.schema.json" },
    "esr":                 { "$ref": "measured_value.schema.json" },
    "dielectric": {
      "type": "array",
      "items": { "type": "string" }
    },
    "placement": {
      "type": "string",
      "enum": ["close", "nearby", "per_pin", "per_component"]
    },
    "quantity": {
      "type": "string",
      "enum": ["1", "per_pin", "per_component"]
    },
    "scope": {
      "type": "string",
      "enum": ["component", "bus"],
      "description": "component: one per IC instance. bus: shared across all devices on the bus."
    },
    "from": { "type": "string" },
    "to":   { "type": "string" }
  }
}
