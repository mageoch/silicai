{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mageoch/silicai/schema/defs/circuit_bus.schema.json",
  "title": "Circuit Bus",
  "description": "A communication bus instantiated in a circuit",
  "type": "object",
  "required": ["id", "type"],
  "properties": {
    "id":    { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["I2C", "SPI", "UART", "USB", "CAN", "Ethernet", "SDIO", "I2S", "SMBus", "1-Wire"]
    },
    "speed": { "$ref": "measured_value.schema.json" }
  },
  "additionalProperties": false
}
