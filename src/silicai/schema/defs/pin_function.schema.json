{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mageoch/silicai/schema/defs/pin_function.schema.json",
  "title": "Pin Function",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "gpio", "reset", "boot_select",
        "clock_in", "clock_out",
        "power", "analog_in", "analog_out", "differential_pair",
        "i2c_scl", "i2c_sda",
        "spi_sck", "spi_mosi", "spi_miso", "spi_cs",
        "uart_tx", "uart_rx",
        "alert", "address_select", "enable", "interrupt", "pwm"
      ]
    },
    "polarity": { "type": "string", "enum": ["active_high", "active_low"] },
    "port":     { "type": "string" },
    "bit":      { "type": "integer" },
    "options": {
      "type": "array",
      "items": { "$ref": "#/$defs/address_select_option" }
    }
  },
  "$defs": {
    "address_select_option": {
      "type": "object",
      "required": ["connect_to", "i2c_address"],
      "properties": {
        "connect_to":  { "type": "string" },
        "i2c_address": { "type": "string" }
      }
    }
  }
}
