{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mageoch.github.io/silicai/schema/circuit.schema.json",
  "title": "SilicAI Circuit",
  "description": "A circuit design referencing components from a SilicAI component library",
  "type": "object",
  "required": ["circuit"],
  "properties": {
    "$schema":         { "type": "string" },
    "$schema_version": { "type": "string" },
    "circuit": {
      "type": "object",
      "required": ["name", "instances"],
      "properties": {
        "name":        { "type": "string", "description": "Human-readable circuit name" },
        "description": { "type": "string", "description": "Brief description of the circuit's purpose" },
        "power_rails": {
          "type": "array",
          "description": "Power rails used in this circuit",
          "items": { "$ref": "defs/circuit_power_rail.schema.json" }
        },
        "buses": {
          "type": "array",
          "description": "Communication buses instantiated in this circuit",
          "items": { "$ref": "defs/circuit_bus.schema.json" }
        },
        "instances": {
          "type": "array",
          "description": "Component instances that make up this circuit",
          "items": { "$ref": "defs/circuit_instance.schema.json" }
        },
        "groups": {
          "type": "array",
          "description": "Logical groupings of instances sharing a common purpose",
          "items": { "$ref": "defs/circuit_group.schema.json" }
        }
      }
    }
  }
}
